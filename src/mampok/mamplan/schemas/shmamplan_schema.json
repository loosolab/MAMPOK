{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SHMamplan",
  "description": "Software Hub deployment configuration. Minimal format for self-service tool deployments. auth=True is an implicit Python-level constant, not stored in this schema.",
  "type": "object",
  "required": ["project", "deployment", "service"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "object",
      "description": "Core project configuration.",
      "required": ["project_id", "tool"],
      "additionalProperties": false,
      "properties": {
        "project_id": { "$ref": "mamplan_schema.json#/definitions/project_id" },
        "tool": { "$ref": "mamplan_schema.json#/definitions/tool" }
      }
    },
    "deployment": {
      "type": "object",
      "description": "Deployment configuration.",
      "required": ["cluster", "bucket", "lifetime", "status", "url"],
      "additionalProperties": false,
      "properties": {
        "cluster": { "$ref": "mamplan_schema.json#/definitions/cluster" },
        "bucket": { "$ref": "mamplan_schema.json#/definitions/bucket" },
        "lifetime": { "$ref": "mamplan_schema.json#/definitions/lifetime" },
        "status": { "$ref": "mamplan_schema.json#/definitions/status" },
        "url": { "$ref": "mamplan_schema.json#/definitions/url" }
      }
    },
    "service": {
      "type": "object",
      "description": "Service metadata.",
      "required": ["owner"],
      "additionalProperties": false,
      "properties": {
        "owner": { "$ref": "mamplan_schema.json#/definitions/owner" }
      }
    },
    "container": {
      "$ref": "mamplan_schema.json#/properties/container"
    }
  }
}
